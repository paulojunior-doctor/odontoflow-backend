# Supabase — use a SERVICE ROLE KEY aqui (nunca a anon key)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Redis (Railway provisiona automaticamente)
REDIS_URL=redis://localhost:6379

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_aqui

# Segurança do webhook (token secreto configurado na Evolution API)
WEBHOOK_SECRET=um_token_secreto_bem_longo_aqui

# Servidor
PORT=3000
NODE_ENV=development
